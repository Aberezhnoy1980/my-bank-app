{
  "title": "MyBank JVM",
  "uid": "mybank-jvm",
  "tags": ["mybank", "jvm"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "JVM heap used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"}) by (application)",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Live threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(jvm_threads_live_threads) by (application)",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Process CPU usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "avg(process_cpu_usage) by (application)",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ]
    }
  ]
}
