# Copy to .env and adjust for local secure contour (host + Docker infra, or full stack).
# Not used automatically by Spring — export variables or pass via docker compose --env-file.

# Spring profile
SPRING_PROFILES_ACTIVE=secure

# Keycloak (browser / JWT issuer)
KEYCLOAK_ISSUER_URI=http://localhost:8090/realms/mybank
KEYCLOAK_OIDC_ISSUER_URI=http://localhost:8090/realms/mybank
KEYCLOAK_TOKEN_URI=http://localhost:8090/realms/mybank/protocol/openid-connect/token
KEYCLOAK_JWK_SET_URI=http://localhost:8090/realms/mybank/protocol/openid-connect/certs
KEYCLOAK_AUTHORIZATION_URI=http://localhost:8090/realms/mybank/protocol/openid-connect/auth

# OAuth2 client secrets (defaults match imported realm)
KEYCLOAK_FRONT_SECRET=front-secret-change-me
KEYCLOAK_SERVICE_SECRET=services-secret-change-me

# Inter-service URLs when JVM runs on host (Gateway on 8081)
APP_ACCOUNTS_BASE_URL=http://localhost:8081
APP_NOTIFICATIONS_BASE_URL=http://localhost:8081
APP_GATEWAY_BASE_URL=http://localhost:8081
CONFIG_SERVER_HOST=localhost

# Postgres (if not using compose defaults)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mybank
POSTGRES_USER=mybank
POSTGRES_PASSWORD=mybank
